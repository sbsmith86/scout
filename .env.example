# Anthropic Claude API
ANTHROPIC_API_KEY=

# Google Sheets / Docs
# GOOGLE_SHEETS_ID: the spreadsheet ID from the Sheet URL
#   e.g. https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_ID=

# Authentication — choose ONE of the two options below:

# Option 1 — Key file (local dev): path to your service account JSON key file
#   1. Create a Google Cloud project and enable the Sheets API + Docs API
#   2. Create a service account and download the JSON key
#   3. Copy config/google-service-account.example.json → config/google-service-account.json and fill it in
#   4. Share the Google Sheet with the service account email address (Editor access)
#   The real key file is gitignored — never commit it.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=config/google-service-account.json

# Option 2 — Individual env vars (Codespaces / environments without a key file):
#   Copy the client_email and private_key fields from the service account JSON key.
#   GOOGLE_PRIVATE_KEY may use literal \n sequences — they are normalised automatically.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Resend (email notifications)
# RESEND_FROM_EMAIL: sender address — the domain MUST be verified in your Resend account.
#   See https://resend.com/docs/dashboard/domains/introduction
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFICATION_EMAIL=

# Dashboard URL (included in notification email; defaults to http://localhost:3000)
DASHBOARD_URL=

# Hunter.io (contact enrichment)
HUNTER_API_KEY=
